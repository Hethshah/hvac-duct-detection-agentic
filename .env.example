# ─────────────────────────────────────────────
#  HVAC Duct Detection — Environment Config
#  Copy this file to .env and fill in your key
#  cp .env.example .env
# ─────────────────────────────────────────────

# Anthropic API key (required)
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── Model assignments (optional — defaults shown) ───
VISION_MODEL=claude-opus-4-7
ORCHESTRATOR_MODEL=claude-sonnet-4-6
INGESTION_MODEL=claude-haiku-4-5-20251001
MEASUREMENT_MODEL=claude-sonnet-4-6
REVIEW_MODEL=claude-sonnet-4-6

# ─── Pipeline settings (optional — defaults shown) ───

# Minimum quality score (0.0–1.0) to accept output without retrying
CONFIDENCE_THRESHOLD=0.85

# Maximum number of reflexion retries before accepting best-effort result
MAX_RETRIES=3

# PDF render resolution — higher = better detection, slower + more memory
DPI=300

# Base output directory (session subdirectories are created inside this)
OUTPUT_DIR=outputs
